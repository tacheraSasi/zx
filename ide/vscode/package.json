{
  "name": "ziex",
  "displayName": "Ziex",
  "description": "Ziex let's you write HTML within your Zig code.",
  "version": "0.1.765",
  "publisher": "ziex",
  "icon": "images/zx-icon.png",
  "private": true,
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "ziex",
    "zig",
    "zx",
    "syntax",
    "highlighting"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ziex-dev/ziex"
  },
  "engines": {
    "vscode": "^1.99.0"
  },
  "extensionDependencies": [
    "ziglang.vscode-zig"
  ],
  "activationEvents": [],
  "main": "./out/extension",
  "contributes": {
    "configurationDefaults": {
      "explorer.autoRevealExclude": {
        "**/.zig-cache": true,
        "**/zig-cache": true
      }
    },
    "configuration": {
      "type": "object",
      "properties": {
        "zx.format.enableZigExpression": {
          "type": "boolean",
          "default": true,
          "description": "Enable autoformatting of Zig expressions (and HTML inside those expressions) that are embedded inside HTML blocks. Default is true. Use the command 'Ziex: Toggle embedded Zig expression formatting' from the Command Palette to toggle this setting."
        },
        "zx.autoCloseTags": {
          "type": "boolean",
          "default": true,
          "description": "Automatically insert closing HTML tags when typing '>' inside HTML fragments in ZX files."
        }
      }
    },
    "commands": [
      {
        "command": "zx.toggleZigExpressionFormatting",
        "title": "ZX: Toggle embedded Zig expression formatting"
      },
      {
        "command": "zx.toggleMultilineStringLiteral",
        "title": "ZX: Toggle multiline string literal"
      }
    ],
    "keybindings": [
      {
        "command": "zx.toggleMultilineStringLiteral",
        "key": "alt+m",
        "mac": "alt+m",
        "when": "editorTextFocus && editorLangId =~ /^(zx|zig)$/"
      },
      {
        "command": "zx.multilineSmartBackspace",
        "key": "backspace",
        "when": "editorTextFocus && !editorHasSelection && editorLangId =~ /^(zx|zig)$/"
      },
      {
        "command": "zx.copyFromMultilineString",
        "key": "ctrl+c",
        "mac": "cmd+c",
        "when": "editorTextFocus && editorHasSelection && editorLangId =~ /^(zx|zig)$/"
      },
      {
        "command": "zx.pasteInMultilineString",
        "key": "ctrl+v",
        "mac": "cmd+v",
        "when": "editorTextFocus && editorLangId =~ /^(zx|zig)$/"
      }
    ],
    "languages": [
      {
        "id": "zx",
        "extensions": [
          ".zx"
        ],
        "aliases": [
          "ZX"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "dark": "./images/zx-icon-dark.svg",
          "light": "./images/zx-icon-light.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "zx",
        "scopeName": "source.zx",
        "path": "./syntaxes/zx.tmLanguage.json",
        "embeddedLanguages": {
          "meta.tag.zx": "zx-tags",
          "meta.tag.attributes.zx": "zx",
          "meta.embedded.expression.zx": "zx"
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "rm -rf out && tsc -b",
    "watch": "tsc -b -w",
    "fmt": "prettier . --write"
  },
  "dependencies": {
    "vscode-html-languageservice": "^5.6.0",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.2",
    "@types/node": "^24.10.0",
    "@types/vscode": "^1.99.0",
    "esbuild": "^0.27.0",
    "prettier": "^3.6.2",
    "pretty-quick": "^4.2.2",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.9.3"
  },
  "prettier": {}
}
